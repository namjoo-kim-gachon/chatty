CHATTY_DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>
CHATTY_DB_POOL_MIN=2
CHATTY_DB_POOL_MAX=10
CHATTY_REDIS_URL=redis://localhost:6379/0

# Google OAuth
CHATTY_GOOGLE_CLIENT_ID=<your-google-client-id>
CHATTY_GOOGLE_CLIENT_SECRET=<your-google-client-secret>
CHATTY_BASE_URL=http://localhost:7799

# Rate limiting (sliding window)
CHATTY_RATE_LIMIT_REQUESTS=100
CHATTY_RATE_LIMIT_WINDOW_SECONDS=60
