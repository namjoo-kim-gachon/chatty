{
  "name": "@namjookim/chatty",
  "version": "0.1.6",
  "description": "Chatty — terminal chat client (TUI + CLI)",
  "homepage": "https://github.com/namjoo-kim-gachon/chatty",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namjoo-kim-gachon/chatty.git"
  },
  "type": "module",
  "bin": {
    "chatty": "dist/index.js",
    "chatty-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "locales"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "cp ../../README.md ./README.md && npm run build",
    "postpublish": "rm -f ./README.md",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "vitest run"
  },
  "dependencies": {
    "eventsource": "^2.0.2",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-unicorn": "^57.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
